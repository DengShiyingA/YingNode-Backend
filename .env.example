# YingNode-Backend environment configuration
# Copy to `.env` and customize. `.env` is gitignored; `.env.example` is committed.

# ---- Security ------------------------------------------------------

# Persistent secret used to derive the Fernet key for encrypting VPS passwords
# at rest, plus Flask's session signing key. If unset, a random value is
# generated on first boot and persisted to data/secret_key. **Back this up**
# — losing it makes all stored VPS passwords unrecoverable.
# YINGNODE_SECRET_KEY=

# Bootstrap admin credentials for the YingNode panel itself. Created on
# first boot only. The password must be at least 8 characters and cannot
# be the literal string "admin" — boot aborts otherwise so no panel ever
# ships with a known default. Change it after first login anyway.
YINGNODE_ADMIN_USERNAME=admin
YINGNODE_ADMIN_PASSWORD=change-me-before-first-boot

# Enforce bearer-token auth on every non-public route. Default is ON.
# Set to 0 only as a temporary bypass while migrating older clients that
# can't yet send a token.
YINGNODE_AUTH_REQUIRED=1

# ---- Database ------------------------------------------------------

# SQLAlchemy URL. Defaults to sqlite:///data/yingnode.db. Only override if
# you've moved to Postgres / MySQL.
# YINGNODE_DATABASE_URL=sqlite:///data/yingnode.db

# ---- Misc ----------------------------------------------------------

# Flask listen address (used by scripts, not by Flask itself). Defaults to
# loopback so fresh installs aren't exposed publicly. Override to 0.0.0.0
# only if you've placed a TLS-terminating reverse proxy in front.
# YINGNODE_HOST=127.0.0.1
# YINGNODE_PORT=5001
