# YingNode-Backend environment configuration
# Copy to `.env` and customize. `.env` is gitignored; `.env.example` is committed.

# ---- Security ------------------------------------------------------

# Persistent secret used to derive the Fernet key for encrypting VPS passwords
# at rest, plus Flask's session signing key. If unset, a random value is
# generated on first boot and persisted to data/secret_key. **Back this up**
# — losing it makes all stored VPS passwords unrecoverable.
# YINGNODE_SECRET_KEY=

# Bootstrap admin credentials for the YingNode panel itself. Created on first
# boot only. Change the password immediately after first login.
YINGNODE_ADMIN_USERNAME=admin
YINGNODE_ADMIN_PASSWORD=admin

# Enforce bearer-token auth on every non-public route. While iOS clients
# are still being updated to send tokens, leave this off (0) — they'll pass
# through, and only /auth/login needs to work. Flip to 1 once the client is
# ready.
YINGNODE_AUTH_REQUIRED=0

# ---- Database ------------------------------------------------------

# SQLAlchemy URL. Defaults to sqlite:///data/yingnode.db. Only override if
# you've moved to Postgres / MySQL.
# YINGNODE_DATABASE_URL=sqlite:///data/yingnode.db

# ---- Misc ----------------------------------------------------------

# Flask listen address (used by scripts, not by Flask itself).
# YINGNODE_HOST=0.0.0.0
# YINGNODE_PORT=5001
